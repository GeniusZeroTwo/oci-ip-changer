# ====== Telegram 配置 ======
# 你的机器人的 Token (从 @BotFather 获取)
TG_BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZ
# 管理员的 Telegram ID (接收完整的换IP统计报告)
ADMIN_TG_ID=123456789
# 允许在网页上操作的客户或管理员 ID 白名单 (多个用逗号隔开)
ALLOWED_TG_USERS=123456789,987654321

# ====== Oracle Cloud (OCI) 配置 ======
OCI_USER_OCID=ocid1.user.oc1..xxxx
OCI_TENANCY_OCID=ocid1.tenancy.oc1..xxxx
OCI_FINGERPRINT=xx:xx:xx:xx:xx:xx:xx:xx:xx:xx
OCI_REGION=ap-seoul-1
# 注意：务必填写 .pem 秘钥文件在 VPS 上的绝对路径
OCI_KEY_FILE=/root/oci-ip-changer/private_key.pem
# 你要操作换IP的那台机器的 OCID
OCI_INSTANCE_OCID=ocid1.instance.oc1..xxxx
